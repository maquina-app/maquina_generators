<% navigation(title: "Job #{@job.job_id}", section: navigation_section_for_status(@job.status)) %>

<div class="py-8">
  <%# Header %>
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-2xl font-bold text-foreground">Job Details</h1>
      <p class="mt-1 text-sm text-muted-foreground">
        <%= job_title(@job) %> &middot; <%= @job.job_id %>
      </p>
    </div>
    <div class="flex items-center gap-2">
      <%= link_to application_jobs_path(@application, @job.status),
          class: "inline-flex items-center gap-2 text-sm text-muted-foreground hover:text-foreground transition-colors" do %>
        <%= icon_for(:arrow_left, class: "size-4") %>
        Back to Jobs
      <% end %>
    </div>
  </div>

  <%# Title with status badge and actions %>
  <%= render "mission_control/jobs/jobs/title", job: @job %>

  <%# Grid layout: details on left, metadata on right %>
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mt-6">
    <div class="lg:col-span-2 space-y-6">
      <%= render "mission_control/jobs/jobs/general_information", job: @job %>
      <%= render "mission_control/jobs/jobs/error_information", job: @job %>
    </div>

    <div class="space-y-6">
      <%= render "mission_control/jobs/jobs/raw_data", job: @job %>
    </div>
  </div>
</div>
