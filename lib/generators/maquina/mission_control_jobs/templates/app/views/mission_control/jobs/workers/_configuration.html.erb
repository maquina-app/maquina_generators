<%= render "components/card" do %>
  <%= render "components/card/header" do %>
    <%= render "components/card/title", text: "Configuration" %>
  <% end %>

  <%= render "components/card/content" do %>
    <pre class="text-xs text-foreground whitespace-pre-wrap break-words font-mono bg-muted/50 p-4 rounded-md border border-border overflow-auto max-h-64"><%= JSON.pretty_generate(worker.configuration) %></pre>
  <% end %>
<% end %>
