<div class="flex items-center gap-3">
  <% if active_filters? %>
    <span class="text-sm text-muted-foreground">
      <strong class="text-foreground"><%= jobs_count %></strong> jobs found
    </span>
  <% end %>

  <% if jobs_status.failed? %>
    <% target = active_filters? ? "selection" : "all" %>

    <%= button_to "Discard #{target}",
        application_bulk_discards_path(@application, **jobs_filter_param),
        method: :post, disabled: jobs_count == 0,
        data: { component: "button", variant: "destructive", size: "sm" },
        form: { data: { turbo_confirm: "This will delete #{jobs_count} jobs and can't be undone. Are you sure?" } } %>

    <%= button_to "Retry #{target}",
        application_bulk_retries_path(@application, **jobs_filter_param),
        method: :post, disabled: jobs_count == 0,
        data: { component: "button", variant: "secondary", size: "sm" } %>
  <% end %>
</div>
