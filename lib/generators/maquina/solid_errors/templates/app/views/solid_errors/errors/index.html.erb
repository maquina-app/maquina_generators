<div class="py-8">
  <!-- Header with tabs -->
  <div class="mb-6 border-b border-border">
    <div class="flex items-center justify-between mb-4">
      <h1 class="text-2xl font-bold text-foreground">Errors</h1>
    </div>

    <!-- Tab Navigation -->
    <nav class="-mb-px flex space-x-4 overflow-x-auto" aria-label="Tabs">
      <%= link_to solid_errors.root_path(scope: :unresolved),
          class: "inline-flex items-center gap-2 whitespace-nowrap px-1 py-4 text-sm font-medium #{ error_scope.unresolved? ? 'border-b-2 border-primary text-primary' : 'text-muted-foreground hover:text-foreground' }" do %>
        <%= icon_for(:clock, class: "size-4") %>
        <span>Unresolved</span>
      <% end %>

      <%= link_to solid_errors.root_path(scope: :resolved),
          class: "inline-flex items-center gap-2 whitespace-nowrap px-1 py-4 text-sm font-medium #{ error_scope.resolved? ? 'border-b-2 border-primary text-primary' : 'text-muted-foreground hover:text-foreground' }" do %>
        <%= icon_for(:check_circle, class: "size-4") %>
        <span>Resolved</span>
      <% end %>
    </nav>
  </div>

  <!-- Error Grid -->
  <% if @errors.any? %>
    <div class="grid grid-cols-1 gap-4">
      <%= render partial: "solid_errors/errors/error_card", collection: @errors, as: :error %>
    </div>
  <% else %>
    <%= empty_state(
      title: error_scope.unresolved? ? "No unresolved errors" : "No resolved errors",
      description: error_scope.unresolved? ? "Everything looks good — no unresolved errors." : "No resolved errors found.",
      icon: :check_circle,
      size: :default
    ) %>
  <% end %>
</div>
