<%# locals: (error:) %>

<%= render "components/card", css_classes: "hover:shadow-md transition-shadow" do %>
  <%= render "components/card/content", spacing: :full do %>
    <div class="flex items-start justify-between gap-4">
      <div class="flex-1 min-w-0">
        <!-- Severity & Status -->
        <div class="flex items-center gap-2 mb-2">
          <%= render "components/badge", variant: severity_badge_variant(error), size: :sm do %><%= error.severity %><% end %>
          <%= render "components/badge", variant: error.resolved? ? :success : :outline, size: :sm do %><%= error.resolved? ? "Resolved" : "Unresolved" %><% end %>
        </div>

        <!-- Error Title -->
        <%= link_to solid_errors.error_path(error),
            class: "text-lg font-semibold text-foreground hover:text-primary transition-colors" do %>
          <code class="break-words"><%= error.exception_class %></code>
        <% end %>

        <div class="mt-1 text-sm text-muted-foreground">
          from <em><code><%= error.source %></code></em>
        </div>

        <!-- Message with overflow handling -->
        <pre class="mt-3 text-sm text-foreground whitespace-pre-wrap font-mono bg-muted/50 p-3 rounded-md overflow-auto max-h-32 break-words"><%= error.message %></pre>
      </div>

      <!-- Action Button -->
      <div class="flex-shrink-0">
        <% if error.resolved? %>
          <%= button_to solid_errors.error_path(error),
              method: :delete,
              form: { data: { turbo_confirm: "Are you sure you want to delete this error?" } },
              data: { component: "button", variant: "destructive" } do %>
            <%= icon_for(:trash, class: "size-4") %>
            <span>Delete</span>
          <% end %>
        <% else %>
          <%= button_to solid_errors.error_path(error),
              method: :patch,
              params: { error: { resolved_at: Time.now } },
              form: { data: { turbo_confirm: "Are you sure you want to resolve this error?" } },
              data: { component: "button", variant: "primary" } do %>
            <%= icon_for(:check_circle, class: "size-4") %>
            <span>Resolve</span>
          <% end %>
        <% end %>
      </div>
    </div>

    <!-- Footer Stats -->
    <div class="mt-4 flex items-center gap-6 text-sm text-muted-foreground border-t border-border pt-4">
      <span>
        <strong class="text-foreground"><%= error.occurrences_count %></strong>
        occurrences
      </span>
      <span>
        Last seen
        <strong class="text-foreground"><%= time_ago_in_words(error.recent_occurrence) %></strong>
        ago
      </span>
    </div>
  <% end %>
<% end %>
