<%# locals: (occurrences:, page:) %>

<%= render "components/card" do %>
  <%= render "components/card/header", layout: :row do %>
    <%= render "components/card/title", text: "Occurrences" %>

    <%= render "components/card/action" do %>
      <div class="flex items-center gap-4 text-sm text-muted-foreground">
        <span>
          <% if page.count.zero? %>
            No occurrences found
          <% elsif page.pages == 1 %>
            <strong><%= page.count %></strong>
            total
          <% else %>
            <strong><%= page.from %>-<%= page.to %></strong>
            of
            <strong><%= page.count %></strong>
          <% end %>
        </span>

        <% if page.pages > 1 %>
          <nav aria-label="Pages" class="flex items-center gap-1">
            <% if (first_page = page.first) %>
              <%= link_to url_for(params.to_unsafe_hash.merge(page: first_page)),
                  data: { component: "button", variant: "outline", size: "icon-sm" },
                  aria_label: "First" do %>
                &laquo;
              <% end %>
            <% else %>
              <span class="inline-flex items-center justify-center w-8 h-8 text-muted-foreground">&laquo;</span>
            <% end %>

            <% if (prev_page = page.prev) %>
              <%= link_to url_for(params.to_unsafe_hash.merge(page: prev_page)),
                  data: { component: "button", variant: "outline", size: "icon-sm" },
                  aria_label: "Previous" do %>
                &lsaquo;
              <% end %>
            <% else %>
              <span class="inline-flex items-center justify-center w-8 h-8 text-muted-foreground">&lsaquo;</span>
            <% end %>

            <% if (next_page = page.next) %>
              <%= link_to url_for(params.to_unsafe_hash.merge(page: next_page)),
                  data: { component: "button", variant: "outline", size: "icon-sm" },
                  aria_label: "Next" do %>
                &rsaquo;
              <% end %>
            <% else %>
              <span class="inline-flex items-center justify-center w-8 h-8 text-muted-foreground">&rsaquo;</span>
            <% end %>

            <% if (last_page = page.last) %>
              <%= link_to url_for(params.to_unsafe_hash.merge(page: last_page)),
                  data: { component: "button", variant: "outline", size: "icon-sm" },
                  aria_label: "Last" do %>
                &raquo;
              <% end %>
            <% else %>
              <span class="inline-flex items-center justify-center w-8 h-8 text-muted-foreground">&raquo;</span>
            <% end %>
          </nav>
        <% end %>
      </div>
    <% end %>
  <% end %>

  <% if occurrences.any? %>
    <%= render "components/card/content", spacing: :full do %>
      <div class="divide-y divide-border">
        <%= render partial: "solid_errors/occurrences/occurrence",
        collection: occurrences,
        as: :occurrence %>
      </div>
    <% end %>
  <% else %>
    <%= empty_state(title: "No occurrences yet", icon: :inbox, size: :compact) %>
  <% end %>
<% end %>
