<%# locals: (error:) %>

<div class="flex items-center justify-between">
  <div>
    <h1 class="text-2xl font-bold text-foreground">Error Details</h1>
    <p class="mt-1 text-sm text-muted-foreground">
      <%= error.exception_class %> &middot; First seen <%= time_ago_in_words(error.occurrences.minimum(:created_at)) %> ago
    </p>
  </div>

  <div class="flex items-center gap-4">
    <%= link_to solid_errors.root_path(scope: error.resolved? ? :resolved : :unresolved),
        class: "inline-flex items-center gap-2 text-sm text-muted-foreground hover:text-foreground transition-colors" do %>
      <%= icon_for(:arrow_left, class: "size-4") %>
      Back to Errors
    <% end %>
  </div>
</div>
