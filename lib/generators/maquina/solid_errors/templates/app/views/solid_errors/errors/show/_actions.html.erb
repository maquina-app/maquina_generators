<%# locals: (error:) %>

<%= render "components/card" do %>
  <%= render "components/card/header" do %>
    <%= render "components/card/title", text: "Actions" %>
  <% end %>

  <%= render "components/card/content" do %>
    <div class="space-y-3">
      <!-- Clean Old Occurrences Button -->
      <% if error.occurrences.count > 10 %>
        <%= button_to main_app.solid_errors_error_occurrences_path(error),
            method: :delete,
            form: { data: { turbo_confirm: "This will delete #{error.occurrences.count - 10} old occurrence#{'s' if error.occurrences.count - 10 != 1}, keeping only the latest 10. Are you sure?" } },
            data: {
              component: "button",
              variant: "secondary"
            },
            class: "w-full justify-center" do %>
          <%= icon_for(:trash, class: "size-4") %>
          <span>Clean Old Occurrences</span>
        <% end %>
      <% end %>

      <!-- Resolve/Delete Button -->
      <% if error.resolved? %>
        <%= render "solid_errors/errors/delete_button", error: error %>
      <% else %>
        <%= render "solid_errors/errors/resolve_button", error: error %>
      <% end %>
    </div>
  <% end %>
<% end %>
