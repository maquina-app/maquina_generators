<%# locals: (error:) %>

<%= button_to solid_errors.error_path(error),
    method: :delete,
    form: { data: { turbo_confirm: "Are you sure you want to delete this error?" } },
    data: { component: "button", variant: "destructive" },
    class: "w-full justify-center" do %>
  <%= icon_for(:trash, class: "size-4") %>
  <span>Delete Error</span>
<% end %>
